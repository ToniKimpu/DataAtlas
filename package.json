{
  "name": "data-atlas",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build:passport": "remotion render PassportRanking out/passport-ranking.mp4",
    "build:headtohead": "remotion render HeadToHead out/head-to-head.mp4",
    "build:chartrace": "remotion render ChartRace out/chart-race.mp4",
    "narrate:internet": "python scripts/generate_internet_narration.py",
    "export:profile": "remotion still ProfileImage out/brand/profile.png",
    "export:cover":   "remotion still CoverImage   out/brand/cover.png",
    "export:brand":   "npm run export:profile && npm run export:cover",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "latest",
    "country-flag-icons": "^1.6.16",
    "d3-geo": "^3.1.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-icons": "^5.6.0",
    "remotion": "latest",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/react": "19.0.0",
    "@types/topojson-client": "^3.1.5",
    "typescript": "5.7.3"
  }
}
